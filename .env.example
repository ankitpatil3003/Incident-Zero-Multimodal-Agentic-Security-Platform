# Mistral AI — get a free key at https://console.mistral.ai/
MISTRAL_API_KEY=

# Backend
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INCIDENT_ZERO_UPLOAD_DIR=

# Mistral model overrides (optional — defaults are free-tier compatible)
MISTRAL_TEXT_MODEL=mistral-large-latest
MISTRAL_VISION_MODEL=mistral-large-latest
MISTRAL_OCR_MODEL=mistral-ocr-latest
